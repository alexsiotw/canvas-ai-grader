{
  "manifest_version": 3,
  "name": "Canvas AI Grading Assistant",
  "version": "1.1",
  "description": "AI-powered grading assistant for Canvas SpeedGrader",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.instructure.com/*",
    "*://*.canvaslms.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/courses/*/gradebook/speed_grader*",
        "*://*.canvaslms.com/courses/*/gradebook/speed_grader*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
